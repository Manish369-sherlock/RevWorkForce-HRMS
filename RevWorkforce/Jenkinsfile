pipeline {
    agent any

    tools {
        jdk "JDK17"
        maven "Maven3"
        nodejs "Node18"
    }

    options {
        skipStagesAfterUnstable()
    }

    environment {
        JAR_NAME = "Workforce-0.0.1-SNAPSHOT.jar"
        REMOTE_DIR = "/home/ec2-user"
        APP_PORT = "8080"
    }

    stages {

        stage("Checkout") {
            steps {
                checkout scm
            }
        }

        stage("Build Backend") {
            steps {
                dir("RevWorkforce") {
                    sh "mvn clean package -DskipTests"
                }
            }
        }

        stage("Build Frontend") {
            steps {
                dir("RevWorkForce-Frontend") {
                    sh """
                    npm install
                    npm run build
                    """
                }
            }
        }

        stage("Deploy Backend to EC2") {
            steps {
                sshPublisher(
                    publishers: [
                        sshPublisherDesc(
                            configName: "ec2-server",
                            verbose: true,
                            transfers: [
                                sshTransfer(
                                    sourceFiles: "RevWorkforce/target/${JAR_NAME}",
                                    removePrefix: "RevWorkforce/target/",
                                    remoteDirectory: "${REMOTE_DIR}",
                                    flatten: true,
                                    execCommand: """
                                        pkill -f "java -jar" || true
                                        nohup java -jar *.jar --server.port=${APP_PORT} > application.log 2>&1 &
                                    """
                                )
                            ]
                        )
                    ]
                )
            }
        }
    }
}
