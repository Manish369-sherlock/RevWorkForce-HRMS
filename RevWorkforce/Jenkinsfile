pipeline {
    agent any

    tools {
        jdk "JDK17"
        maven "Maven3"
        nodejs "Node18"
    }

    environment {
        JAR_NAME = "Workforce-0.0.1-SNAPSHOT.jar"
        REMOTE_DIR = "/home/ec2-user"
    }

    stages {

        stage("Checkout Code") {
            steps {
                echo "Cloning repository from GitHub"
                checkout scm
            }
        }

        stage("Build Backend (Spring Boot)") {
            steps {
                dir("RevWorkforce") {
                    echo "Building Spring Boot backend"
                    bat "mvn clean package -DskipTests"
                }
            }
        }

        stage("Verify Backend Build") {
            steps {
                dir("RevWorkforce") {
                    echo "Verifying backend JAR"
                    bat "dir target"
                }
            }
        }

        stage("Build Frontend (Angular)") {
            steps {
                dir("RevWorkForce-Frontend") {
                    echo "Installing frontend dependencies"
                    bat "npm install"

                    echo "Building Angular application"
                    bat "npm run build"
                }
            }
        }

        stage("Verify Frontend Build") {
            steps {
                dir("RevWorkForce-Frontend") {
                    echo "Checking Angular dist folder"
                    bat "dir dist"
                }
            }
        }

        stage("Deploy Backend to EC2") {
            steps {
                echo "Deploying backend to EC2 instance"

                sshPublisher(
                    publishers: [
                        sshPublisherDesc(
                            configName: "ec2-server",

                            transfers: [
                                sshTransfer(
                                    sourceFiles: "RevWorkforce/target/${JAR_NAME}",
                                    removePrefix: "RevWorkforce/target",
                                    remoteDirectory: "${REMOTE_DIR}",

                                    execCommand: '''
                                    echo "===== Starting Deployment ====="
                                    
                                    echo "Stopping previous app..."
                                    pkill -f Workforce-0.0.1-SNAPSHOT.jar || true
                                    
                                    sleep 5
                                    
                                    echo "Starting new app..."
                                    nohup java -jar /home/ec2-user/Workforce-0.0.1-SNAPSHOT.jar > /home/ec2-user/app.log 2>&1 &
                                    
                                    sleep 10
                                    
                                    echo "Checking running process..."
                                    ps -ef | grep Workforce
                                    
                                    echo "Checking port 8080..."
                                    netstat -tulnp | grep 8080 || true
                                    
                                    echo "===== Deployment Completed ====="
                                    '''
                                )
                            ]
                        )
                    ]
                )
            }
        }
    }

    post {

        success {
            echo "Pipeline executed successfully"
            echo "Application deployed to EC2"
        }

        failure {
            echo "Pipeline failed. Check Jenkins console logs."
        }

        unstable {
            echo "Pipeline finished but deployment may need verification."
        }
    }
}
