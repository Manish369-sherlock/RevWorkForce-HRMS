pipeline {
    agent any

    tools {
        jdk "JDK17"
        maven "Maven3"
        nodejs "Node18"
    }

    environment {
        JAR_NAME = "Workforce-0.0.1-SNAPSHOT.jar"
    }

    stages {

        stage("Checkout Code") {
            steps {
                checkout scm
            }
        }

        stage("Build Backend (Spring Boot)") {
            steps {
                dir("RevWorkforce") {
                    bat "mvn clean package -DskipTests"
                }
            }
        }

        stage("Verify Backend Build") {
            steps {
                dir("RevWorkforce") {
                    bat "dir target"
                }
            }
        }

        stage("Build Frontend (Angular)") {
            steps {
                dir("RevWorkForce-Frontend") {
                    bat "npm install"
                    bat "npm run build"
                }
            }
        }

        stage("Verify Frontend Build") {
            steps {
                dir("RevWorkForce-Frontend") {
                    bat "dir dist"
                }
            }
        }

        stage("Deployment Stage") {
            steps {
                echo "Build completed successfully"
                echo "Backend JAR created in RevWorkforce/target"
                echo "Frontend build created in RevWorkForce-Frontend/dist"
            }
        }
    }

    post {
        success {
            echo "Pipeline executed successfully"
        }
        failure {
            echo "Pipeline failed. Check console output."
        }
    }
}
